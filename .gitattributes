# ============================================================
# Git LFS + Unity attributes for the Prison Escape project
# ------------------------------------------------------------
# Macro: Unity YAML text assets — keep textual diffs but avoid
# line-ending corruption (-text disables CRLF munging).
[attr]unityyaml -text diff

# Macro: large binary assets tracked with Git LFS.
[attr]lfs -text filter=lfs diff=lfs merge=lfs
# ============================================================

# ----------------------------
# Source / config (plain text)
# ----------------------------
*.cs        text diff=csharp
*.cginc     text
*.compute   text
*.shader    text
*.hlsl      text
*.uxml      text
*.uss       text
*.json      text
*.md        text
*.txt       text
*.xml       text
*.yml       text
*.yaml      text
*.asmdef    text
*.asmref    text

